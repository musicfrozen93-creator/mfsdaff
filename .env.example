# ─────────────────────────────────────────────
# V2 Multi-Account Crypto Scalping Bot — Environment
# ─────────────────────────────────────────────

# ══════════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ══════════════════════════════════════════════
# BINANCE FUTURES API (Master Account — for scanning)
# ══════════════════════════════════════════════
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Set to "false" for mainnet trading (REAL MONEY)
BINANCE_TESTNET=true

# ══════════════════════════════════════════════
# OPENAI (AI Decision Verification)
# ══════════════════════════════════════════════
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ══════════════════════════════════════════════
# ENCRYPTION (API Key Security)
# ══════════════════════════════════════════════
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# ══════════════════════════════════════════════
# TELEGRAM BOT
# ══════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ══════════════════════════════════════════════
# TRADING PARAMETERS
# ══════════════════════════════════════════════
MIN_CONFIDENCE=65

# ══════════════════════════════════════════════
# TRADE LIMITS
# ══════════════════════════════════════════════
DAILY_MAX_TRADES=100
HOURLY_MAX_TRADES=10
COIN_COOLDOWN_MINUTES=30

# ══════════════════════════════════════════════
# RISK CONTROLS
# ══════════════════════════════════════════════
MAX_VOLATILITY_PCT=5.0
DAILY_PROFIT_LIMIT_PCT=150.0
DAILY_LOSS_LIMIT_PCT=-20.0
LOSS_COOLDOWN_COUNT=3
LOSS_COOLDOWN_MINUTES=15
DRAWDOWN_PAUSE_PCT=-10.0
MAX_COIN_REPEATS_PER_HOUR=2
